<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="production_mode_res_config_settings_view_form" model="ir.ui.view">
        <field name="name">production.mode.res.config.settings.view.form</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="priority" eval="50"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app string="Production Mode" name="production_mode_settings">
                    <block title="Production Mode" name="production_mode_settings_block">
                        <setting id="production_mode_enabled_setting"
                                 string="Enable Production Mode"
                                 help="When enabled, production mode restrictions apply only to users in the Production Mode Restricted group. Login and database pages remain global.">
                            <field name="enable_production_mode"/>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>
</odoo>
